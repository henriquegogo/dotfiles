[user]
	name = Henrique Gogó
	email = henriquegogo@gmail.com
[push]
	default = simple
[core]
	editor = nvim
[diff]
	tool = nvimdiff
[difftool]
	prompt = false
[merge]
	tool = nvimdiff
[alias]
	sync = "!for repo in $(echo */); do if [ -d \"$repo/.git\" ]; then echo \"$repo\"; git -C \"$repo\" pull; echo; fi; done"
	history = "log --format='%Cred%h %Creset%s (%Cgreen%an) %Creset- %Cblue%cr' --graph"
